{
  "name": "comparecreditcards",
  "version": "2.0.0",
  "description": "One-shot CDR-to-Supabase credit-card ingest for the creditcardsUI app",
  "main": "src/ingest.js",
  "type": "module",
  "scripts": {
    "ingest": "node --env-file=.env src/ingest.js",
    "ingest:dry": "INGEST_DRY_RUN=1 node --env-file=.env src/ingest.js",
    "ingest:reextract": "INGEST_REEXTRACT_ONLY=1 node --env-file=.env src/ingest.js",
    "ingest:loans": "node --env-file=.env src/ingestHomeLoans.js",
    "ingest:loans:dry": "INGEST_DRY_RUN=1 node --env-file=.env src/ingestHomeLoans.js",
    "test": "node --test \"test/**/*.test.js\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.6.7"
  }
}
