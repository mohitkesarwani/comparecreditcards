# Supabase target (Project Settings → API in the Supabase dashboard)
SUPABASE_URL=
# Use the SERVICE ROLE key — the ingest writes to credit_cards and needs to
# bypass RLS. Never expose this key in the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# CDR API headers (rarely need changing)
DEFAULT_X_V=4
X_V_RETRY_FROM=3
X_V_RETRY_TO=4
# Optional JSON overrides. Leave blank to use the defaults built from DEFAULT_X_V.
GET_PRODUCTS_HEADERS=
GET_PRODUCT_DETAIL_HEADERS=
# Per-request HTTP timeout in milliseconds.
CDR_TIMEOUT_MS=15000

# Optional run-time scoping
# Comma-separated bank name allowlist; must match src/constants/banks.js exactly.
INGEST_BANKS=
# Cap products per bank (handy for smoke-testing).
INGEST_LIMIT_PER_BANK=
# Set to 1 to fetch without writing to Supabase.
INGEST_DRY_RUN=
